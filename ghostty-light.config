# Ghostty 配置 —— 简洁浅色风格
# 安装位置： ~/.config/ghostty/config
# 重载快捷键： Cmd + Shift + ,
# 注意：Ghostty 不支持行内注释，# 必须独占一行

# ---------- 配色：Gruvbox Light（暖棕调，无紫色） ----------
background = fbf1c7
foreground = 3c3836
cursor-color = 3c3836
selection-background = ebdbb2
selection-foreground = 3c3836

palette = 0=#fbf1c7
palette = 1=#cc241d
palette = 2=#98971a
palette = 3=#d79921
palette = 4=#458588
palette = 5=#b16286
palette = 6=#689d6a
palette = 7=#7c6f64
palette = 8=#928374
palette = 9=#9d0006
palette = 10=#79740e
palette = 11=#b57614
palette = 12=#076678
palette = 13=#8f3f71
palette = 14=#427b58
palette = 15=#3c3836

# ---------- 字体 ----------
# 推荐： brew install --cask font-jetbrains-mono-nerd-font
font-family = JetBrainsMono Nerd Font
font-size = 12
# 行距，阅读更舒服
adjust-cell-height = 15%

# ---------- 窗口 ----------
window-padding-x = 8
window-padding-y = 4
window-padding-balance = true
window-decoration = true
# 标题栏样式： native / transparent / tabs / hidden
macos-titlebar-style = transparent
background-opacity = 0.98

# ---------- 光标 ----------
cursor-style = block
cursor-style-blink = false
shell-integration-features = cursor,sudo,title

# ---------- 体验细节 ----------
copy-on-select = clipboard
mouse-hide-while-typing = true
confirm-close-surface = false
clipboard-trim-trailing-spaces = true
scrollback-limit = 100000

# ---------- 快捷键（macOS 习惯） ----------
keybind = cmd+t=new_tab
keybind = cmd+w=close_surface
keybind = cmd+d=new_split:right
keybind = cmd+shift+d=new_split:down
keybind = cmd+left_bracket=previous_tab
keybind = cmd+right_bracket=next_tab
keybind = cmd+k=clear_screen
